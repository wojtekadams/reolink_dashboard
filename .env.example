# Copy this file to .env and fill in your values:  cp .env.example .env
# docker compose picks up .env automatically.

NVR_IP=192.168.1.100
NVR_USER=admin
NVR_PASS=your_password_here

# Channel count is discovered automatically.
# auto = all cameras; set a number to cap (e.g. 4 = channels 0-3 only).
NVR_CHANNEL=auto

# How often to poll the hub (seconds). Frequent polling wakes sleeping cameras.
POLL_INTERVAL=300

# Default chart window and history retention.
HISTORY_HOURS=24
RETENTION_DAYS=30
